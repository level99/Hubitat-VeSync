# Cross-platform line-ending discipline for Hubitat-VeSync.
# Without this, Git relies on each contributor's core.autocrlf setting,
# which is fragile across Windows/macOS/Linux and led to a CRLF->LF
# warning during the initial harness commit. Explicit per-pattern rules
# below remove that ambiguity.

# Default: auto-detect text files, normalize to LF on commit
* text=auto eol=lf

# Windows-specific scripts MUST be CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix shell scripts MUST be LF
*.sh text eol=lf
gradlew text eol=lf

# Source / config files: LF
*.groovy text eol=lf
*.gradle text eol=lf
*.java text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.properties text eol=lf
*.xml text eol=lf

# Binary files: no conversion
*.jar binary
*.png binary
*.svg binary
*.pdf binary
*.zip binary
*.ico binary
*.gz binary
